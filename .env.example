# ═══════════════════════════════════════════════════════════
# KINCIRCLE — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file as .env and fill in the values.
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════

# ─── Supabase (Settings → API) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ─── Database ────────────────────────────────────────────
# Для Vercel: используй Transaction pooler URL (порт 6543, БЕЗ pgbouncer=true)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Прямой коннект для миграций (порт 5432, хост db.xxx.supabase.co)
DIRECT_DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── JWT (Settings → API → JWT Keys → Legacy) ──────────
JWT_SECRET=your-legacy-jwt-secret-here

# ─── Telegram Bot (@BotFather) ──────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
